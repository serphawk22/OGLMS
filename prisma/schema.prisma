generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

model Organization {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  members     OrganizationMember[]
  courses     Course[]
  dailyBites  DailyBite[]
}

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  password              String               // ADDED for custom JWT auth
  name                  String?
  expertise             String[]             @default([])
  memberships           OrganizationMember[]
  enrollments           Enrollment[]
  coursesCreated        Course[]             @relation("CourseCreator")
  notifications         Notification[]
  chats                 Chat[]
  submissions           AssignmentSubmission[]
  reviews               Review[]
  quizSubmissions       QuizSubmission[]
  recordedClasses       RecordedClass[]
  materialViews         MaterialView[]
  adminCommentsAuthored AdminComment[]       @relation("AdminCommentAuthor")
  adminCommentsReceived AdminComment[]       @relation("AdminCommentStudent")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role         @default(STUDENT)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Course {
  id               String            @id @default(cuid())
  title            String
  description      String?
  published        Boolean           @default(false)
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creatorId        String
  creator          User              @relation("CourseCreator", fields: [creatorId], references: [id])
  modules          Module[]
  assignments      Assignment[]
  readingMaterials ReadingMaterial[]
  quizzes          Quiz[]
  enrollments      Enrollment[]
  events           Event[]
  liveSessions     LiveSession[]
  chats            Chat[]
  reviews          Review[]
  recordedClasses  RecordedClass[]
  adminComments    AdminComment[]

  @@index([organizationId])
  @@index([creatorId])
}

model Module {
  id              String          @id @default(cuid())
  title           String
  courseId        String
  course          Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons         Lesson[]
  liveSessions    LiveSession[]   // module-specific live classes (optional)
  recordedClasses RecordedClass[] // module-specific recordings (optional)

  @@index([courseId])
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  videoUrl    String?
  driveLink   String?
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  progress  Float    @default(0.0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model DailyBite {
  id             String       @id @default(cuid())
  title          String
  videoUrl       String
  date           DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Assignment {
  id             String                 @id @default(cuid())
  title          String
  description    String?
  driveLink      String?
  courseId       String
  course         Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions    AssignmentSubmission[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  driveLink    String
  grade        Int?
  maxGrade     Int        @default(100)
  feedback     String?
  submittedAt  DateTime   @default(now())
  gradedAt     DateTime?
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

model ReadingMaterial {
  id            String         @id @default(cuid())
  title         String
  link          String
  courseId      String
  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  materialViews MaterialView[]
}

model Quiz {
  id            String          @id @default(cuid())
  title         String
  courseId      String
  retryEnabled  Boolean         @default(false)
  course        Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions     Question[]
  submissions   QuizSubmission[]
  createdAt     DateTime        @default(now())
}

model QuizSubmission {
  id            String   @id @default(cuid())
  quizId        String
  studentId     String
  answers       Json     // { questionId: selectedOptionIndex | "essay_text" }
  obtainedMarks Int
  totalMarks    Int
  submittedAt   DateTime @default(now())
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([quizId, studentId])
  @@index([quizId])
  @@index([studentId])
}

model Question {
  id            String   @id @default(cuid())
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type          String   // "MCQ" or "ESSAY"
  text          String
  options       String[] // Only for MCQ
  correctOption Int?     // Index of correct option (0-3) for MCQ
  points        Int      @default(1)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  type      String   // "COURSE" | "ASSIGNMENT" | "MODULE"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Event {
  id        String    @id @default(cuid())
  title     String
  date      DateTime
  type      String    // "ASSIGNMENT_DEADLINE" | "MODULE_PUBLISH" | "COURSE_PUBLISHED"
  courseId  String?
  course    Course?   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

enum LiveSessionStatus {
  SCHEDULED
  ONGOING
  COMPLETED
}

model LiveSession {
  id           String            @id @default(cuid())
  roomId       String            @unique
  title        String
  courseId     String
  course       Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  // Optional: link this session to a specific module (null = course-level, backward-compatible)
  moduleId     String?
  module       Module?           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  status       LiveSessionStatus @default(SCHEDULED)
  scheduledAt  DateTime          @default(now())
  recordingUrl String?
  createdAt    DateTime          @default(now())

  @@index([courseId])
  @@index([moduleId])
}

// --- AI Chat History ---

model Chat {
  id        String        @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId])
  @@index([courseId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

// --- Course Reviews ---

model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1-5 stars
  comment   String
  courseId  String
  studentId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([courseId])
  @@index([studentId])
}

// ── Recorded Classes (auto-uploaded from live sessions via Cloudinary) ─────────

model RecordedClass {
  id           String   @id @default(cuid())
  courseId     String
  instructorId String
  title        String
  videoUrl     String
  duration     Int?     // in seconds
  // Optional: link this recording to a specific module (null = course-level, backward-compatible)
  moduleId     String?
  module       Module?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor   User     @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([instructorId])
  @@index([moduleId])
}

// ── Per-student reading material view tracking ──────────────────────────────

model MaterialView {
  id         String          @id @default(cuid())
  materialId String
  studentId  String
  viewedAt   DateTime        @default(now())
  viewCount  Int             @default(1)
  material   ReadingMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  student    User            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([materialId, studentId])
  @@index([materialId])
  @@index([studentId])
}

// ── Admin Comments (course-level & student-level, visibility enforced by API) ──

model AdminComment {
  id         String   @id @default(cuid())
  content    String
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation("AdminCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetType String   // "COURSE" | "STUDENT"
  studentId  String?
  student    User?    @relation("AdminCommentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([courseId])
  @@index([authorId])
  @@index([studentId])
}
